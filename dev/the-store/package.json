{
  "name": "the-store",
  "description": "An online store selling a variety of high quality products across many different categories.",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:mcp": "cross-env TARGET=mcp vite",
    "dev:openai": "cross-env TARGET=openai vite",
    "dev:e2e": "vite build --watch",
    "build": "tsc -b && vite build",
    "build:staging": "tsc -b && vite build --mode staging",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write src vite.config.ts",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/client": "^4.1.5",
    "@apollo/client-ai-apps": "^0.5.1",
    "@graphql-tools/graphql-tag-pluck": "^8.3.23",
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@tailwindcss/vite": "^4.1.17",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "crypto-hash": "^4.0.0",
    "glob": "^11.0.3",
    "graphql": "^16.12.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router": "^7.9.6",
    "rxjs": "^7.8.2",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@mcpjam/inspector": "^1.3.10",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "cross-env": "^10.1.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
